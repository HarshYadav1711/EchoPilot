# Copy to `.env` and adjust if your tooling loads dotenv (optional).
# EchoPilot reads these via `os.environ` in core/config.py.

# Ollama HTTP API (default: local)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_INTENT_TEMPERATURE=0.1
INTENT_CONFIDENCE_THRESHOLD=0.55

# faster-whisper (default tiny = laptop-friendly; try "base" for accuracy)
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_TEMPERATURE=0
WHISPER_VAD_FILTER=true
WHISPER_MIN_DURATION_S=0.25
WHISPER_SILENCE_PEAK=0.00003
